{
  "firestore": {
    "rules":   "firestore.rules",
    "indexes": "firestore.indexes.json"
  },

  "functions": [
    {
      "source":   "functions",
      "codebase": "api",
      "ignore":   ["node_modules", ".git", "*.local"]
    }
  ],

  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source":   "/api/**",
        "function": "api",
        "region":   "us-central1"
      },
      {
        "source":      "**",
        "destination": "/index.html"
      }
    ]
  }
}
