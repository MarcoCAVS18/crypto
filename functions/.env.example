# ── Variables de entorno para Firebase Functions ──────────────────────────────
#
# EN PRODUCCIÓN: NO uses este archivo.
# Configurá los secretos con Firebase Secret Manager:
#   firebase secrets:set GROQ_API_KEY
#
# PARA EMULACIÓN LOCAL (firebase emulators:start):
#   Copiá este archivo como .env y completá los valores reales.
#   El emulador lee automáticamente functions/.env
#
# IMPORTANTE: .env está en .gitignore — nunca lo commiteés.

GROQ_API_KEY=tu_groq_api_key_aqui
