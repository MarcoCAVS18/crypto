# ── URL del backend ────────────────────────────────────────────────────────────
#
# Firebase Hosting (producción):
#   VITE_API_URL=/api
#   Las requests a /api/** se reescriben a la Cloud Function automáticamente.
#
# Desarrollo local (emulador o Render):
#   VITE_API_URL=http://localhost:3001/api
#
VITE_API_URL=/api

# ── Firebase — obtener en: Firebase Console → Project Settings → General ───────
# Estas credenciales son PÚBLICAS (la seguridad se gestiona en firestore.rules).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
