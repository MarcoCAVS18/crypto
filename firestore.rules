rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // portfolio_operations — acceso libre (app personal, sin autenticación)
    match /portfolio_operations/{docId} {
      allow read, write: if true;
    }

    // user_profiles — almacena el hash SHA-256 del PIN por perfil.
    // El hash no es reversible y no contiene datos sensibles en texto plano.
    match /user_profiles/{userId} {
      allow read, write: if true;
    }
  }
}
