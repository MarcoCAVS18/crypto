rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // portfolio_operations — acceso libre (app personal, sin autenticación)
    // Si en el futuro se agrega Firebase Auth, reemplazar `if true` por
    // `if request.auth != null`
    match /portfolio_operations/{docId} {
      allow read, write: if true;
    }
  }
}
