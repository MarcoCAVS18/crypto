rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Operaciones del portfolio — lectura/escritura desde el cliente React
    match /portfolio_operations/{docId} {
      allow read, write: if true;
    }

    // Perfiles de usuario (hash SHA-256 del PIN) — escritura solo al configurar
    match /user_profiles/{userId} {
      allow read, write: if true;
    }

    // Historial de decisiones — solo lectura pública (escritura solo desde Functions)
    match /decisions/{docId} {
      allow read:  if true;
      allow write: if false;
    }

    // Cachés internas de la Function — solo acceso desde el servidor (Admin SDK)
    match /_cache/{docId} {
      allow read, write: if false;
    }
    match /_ai_cache/{docId} {
      allow read, write: if false;
    }
  }
}
